+def action_fingerprint(raw: Any) -> str:
+    if isinstance(raw, dict):
+        action_type = str(raw.get("action_type") or raw.get("type") or raw.get("action") or raw.get("name") or "")
+        action_id = str(raw.get("action_id") or raw.get("id") or "")
+        payload = raw.get("payload") if isinstance(raw.get("payload"), dict) else {}
+        evidence_id = str(raw.get("evidence_id") or payload.get("evidence_ref") or "")
+        path = str(raw.get("path") or raw.get("source_record_id") or payload.get("path") or payload.get("source_record") or "")
+        return "|".join([action_type, action_id, evidence_id, path])
+    return str(raw)
+
