+def collapse_repeated_sequence(values: list[str]) -> list[str]:
+    items = [str(item) for item in values if str(item)]
+    if len(items) < 2 or len(items) % 2:
+        return items
+    half = len(items) // 2
+    if items[:half] == items[half:]:
+        return items[:half]
+    return items
+
