+def has_duplicate_external_send_actions(data: dict[str, Any]) -> bool:
+    tool = data.get("tool_evidence") if isinstance(data.get("tool_evidence"), dict) else {}
+    package = tool.get("outbound_package") if isinstance(tool.get("outbound_package"), dict) else {}
+    for actions in (tool.get("send_actions"), tool.get("outbound_send_actions"), package.get("send_actions")):
+        if not isinstance(actions, list) or len(actions) < 2:
+            continue
+        fingerprints = [action_fingerprint(item) for item in actions if action_fingerprint(item)]
+        if len(fingerprints) != len(set(fingerprints)):
+            return True
+    return False
 
 
