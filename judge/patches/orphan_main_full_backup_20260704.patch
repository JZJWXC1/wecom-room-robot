+    fee = "服务费按免押金额和租期收，3个月约5.5%，3-6个月约7%，6-12个月约8%，最终以支付宝页面为准。"
+    if asks_fee and asks_condition:
+        return base + self_check + fee
+    if asks_fee:
+        return base + fee
+    if asks_condition:
