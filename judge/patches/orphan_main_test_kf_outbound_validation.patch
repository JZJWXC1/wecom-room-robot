+def test_l3_rewrites_customer_visible_internal_binding_leaks() -> None:
+    bad_replies = [
+        "客户要查询素材，但工具未绑定到具体房源。",
+        "客户选择了第1套、第2套，但上一轮只有 0 套候选。",
+        "候选1 石桥铭苑 21-1201A 租金4500",
+        "星桥锦绣嘉苑20-1606A:图片 暂未找到可发送图片。",
+    ]
+
+    for reply in bad_replies:
+        package = _base_package()
+        package.reply_text = reply
+
+        result = validate_prepared_outbound_package(package)
+
+        assert result.status == ValidationStatus.REWRITE_REQUIRED
+        assert result.facts_passed is True
+        assert "l3.customer_visible_internal_leak" in _codes(result)
+
