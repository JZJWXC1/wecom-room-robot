+def _looks_like_candidate_refinement_query(query_text: str, proof: dict[str, Any] | None = None) -> bool:
+    text = str(query_text or "")
+    if not text:
+        return False
+    if _has_explicit_candidate_selection(text) or _room_refs_from_text(text):
+        return False
+    proof = dict(proof or {})
+    has_new_scope = bool(
+        proof.get("area")
+        or proof.get("communities")
+        or proof.get("budget_range")
+        or proof.get("layout")
+    )
+    parsed = parse_inventory_query(text)
+    has_refine_feature = bool(parsed.feature_aliases) or any(
+        word in text
+        for word in (
+            "优先",
+            "独卫",
+            "独立厨房",
+            "独厨",
+            "厨卫",
+            "阳台",
+            "燃气",
+            "朝南",
+            "装修",
+            "精装",
+            "马上入住",
+            "马上住",
+            "随时入住",
+            "空房",
+            "已空",
+            "现在空",
+        )
+    )
+    return has_refine_feature and not has_new_scope
+
