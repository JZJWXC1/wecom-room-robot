+        response_strategy=ResponseStrategy.SEND_MEDIA,
+        tasks=[
+            TaskAtom(
+                task_id="task-image",
+                task_type="send_image",
+                user_text="这套图片发我",
+                required_tools=["media.image"],
+            )
+        ],
+    )
+    bundle = ToolEvidenceBundle(
+        conversation_id="conv-missing-colon",
+        turn_id="turn-missing-colon",
+        case_id="case-missing-colon",
+        inventory_snapshot_id="snap-missing-colon",
+        tool_name="llm2.test.missing_colon",
+        evidence=[
+            EvidenceItem(
+                evidence_id="evd-missing-media-1",
+                listing_id="lst-1606a",
+                evidence_type="missing_media",
+                summary="星桥锦绣嘉苑20-1606A:图片 暂未找到可发送图片。",
+                field_values={"media_kind": "image", "label": "星桥锦绣嘉苑20-1606A"},
+            ),
+        ],
+        raw_tool_result={"actions": ["search_inventory", "send_image", "explain_missing_media"]},
+    )
+
+    package = compose_kf_outbound(
+        packet,
+        bundle,
+        ResponseStrategy.SEND_MEDIA,
