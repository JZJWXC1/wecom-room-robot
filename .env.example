APP_ENV=production
PUBLIC_BASE_URL=https://your-domain.example
LOG_LEVEL=INFO

# 企业微信应用 / 客服回调
WECOM_CONNECTION_MODE=long_connection
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
WECOM_AGENT_ID=1000002
WECOM_SECRET=your_agent_secret
WECOM_TOKEN=your_callback_token
WECOM_AES_KEY=your_43_char_encoding_aes_key

WECOM_AIBOT_BOT_ID=your_aibot_bot_id
WECOM_AIBOT_SECRET=your_aibot_secret

WECOM_KF_SECRET=your_kf_secret
WECOM_KF_TOKEN=your_kf_callback_token
WECOM_KF_AES_KEY=your_kf_43_char_encoding_aes_key
WECOM_KF_STATE_PATH=data/wecom_kf_state.json
WECOM_KF_SYNC_LIMIT=100
WECOM_KF_SYNC_MAX_PAGES=3
WECOM_KF_WELCOME_INTERVAL_SECONDS=600
WECOM_KF_WELCOME_TEXT=你好，我在。找房、要视频、看密码、发房源表都可以直接说。\n\n比如：\n“万达1500左右还有哪些？”\n“新天地4000左右两室有吗？”\n“这套视频发我”\n“今天能看吗，密码多少？”\n“房源表发我一下”\n\n小区名、房号记不清也没事，发个大概我来帮你对。
WECOM_KF_SATISFACTION_DELAY_SECONDS=300
WECOM_KF_SATISFACTION_PROMPT=这次回复有帮到你吗？满意的话回“满意”，不满意直接告诉我哪里没解决，我马上改。

# LLM：默认使用阿里云百炼 OpenAI-compatible API
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-flash
DASHSCOPE_REWRITE_MODEL=qwen-flash
DASHSCOPE_PLANNER_MODEL=qwen-flash
DASHSCOPE_REPLY_MODEL=qwen-plus
DASHSCOPE_SELFCHECK_MODEL=qwen-flash
DASHSCOPE_RETRY_MODEL=qwen-flash
DASHSCOPE_VISION_MODEL=qwen3.5-omni-plus
LLM_REWRITE_PROVIDER=dashscope
LLM_PLANNER_PROVIDER=dashscope
LLM_REPLY_PROVIDER=dashscope
LLM_SELFCHECK_PROVIDER=dashscope
LLM_RETRY_PROVIDER=dashscope
LLM_VISION_PROVIDER=dashscope

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REWRITE_MODEL=deepseek-chat
DEEPSEEK_PLANNER_MODEL=deepseek-chat
DEEPSEEK_REPLY_MODEL=deepseek-chat
DEEPSEEK_SELFCHECK_MODEL=deepseek-chat
DEEPSEEK_RETRY_MODEL=deepseek-reasoner

# 客服 Agentic RAG
KF_AGENTIC_RAG_ENABLED=true
KF_AGENTIC_RAG_KNOWLEDGE_DIR=knowledge/kf
KF_AGENTIC_RAG_MAX_EVIDENCE=5
KF_HUMANIZED_REPLY_ENABLED=false
KF_HUMANIZED_REPLY_MAX_BUBBLES=3
KF_HUMANIZED_REPLY_MAX_CHARS=90
KF_HUMANIZED_TYPING_DELAY_ENABLED=false
KF_HUMANIZED_TYPING_DELAY_BASE_SECONDS=0.6
KF_HUMANIZED_TYPING_DELAY_PER_CHAR_SECONDS=0.05
KF_HUMANIZED_TYPING_DELAY_CAP_SECONDS=3.5

# 房源表和素材库
INVENTORY_SOURCE=local_image
KDOCS_PUBLIC_URL=
INVENTORY_CACHE_PATH=data/inventory_cache.csv
INVENTORY_CACHE_META_PATH=data/inventory_cache_meta.json
REWRITE_INVENTORY_INDEX_PATH=data/rewrite_inventory_index.json
INVENTORY_IMAGE_CACHE_PATH=data/inventory_image_cache.md
INVENTORY_REFRESH_SECONDS=300
INVENTORY_SNAPSHOT_MODE=disabled
INVENTORY_SNAPSHOT_SHADOW_ROOT=data/inventory_snapshots_shadow
INVENTORY_SNAPSHOT_SHADOW_STALE_SECONDS=86400
INVENTORY_SNAPSHOT_SHADOW_REQUIRED_PASSES=3
INVENTORY_SNAPSHOT_SHADOW_TIMEOUT_SECONDS=10
INVENTORY_SNAPSHOT_SHADOW_REPORT_RETENTION=30
ROOM_DATABASE_PATH=room_database
INVENTORY_IMAGE_PATH=room_database/inventory.png
INVENTORY_IMAGE_GLOB=room_database/inventory_*.png
MEDIA_ROOT=media/rooms

# 飞书应用态凭证，不依赖浏览器授权
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_BITABLE_TABLE_ID=your_bitable_table_id
FEISHU_BITABLE_VIEW_ID=
FEISHU_DRIVE_ROOT_FOLDER_TOKEN=your_drive_folder_token
FEISHU_INVENTORY_DRIVE_FOLDER_TOKEN=your_inventory_drive_folder_token
FEISHU_SYNC_MEDIA_ON_STARTUP=false
FEISHU_INVENTORY_SHEET_TOKEN=your_sheet_token
FEISHU_INVENTORY_SHEET_SYNC_ON_STARTUP=false
FEISHU_INVENTORY_SHEET_CHECK_SECONDS=300
INVENTORY_IMAGE_SYNC_STATE_PATH=data/inventory_image_sync_state.json

# 线索与中介统计
FEISHU_LEADS_APP_TOKEN=your_leads_bitable_app_token
FEISHU_LEADS_TABLE_ID=your_leads_table_id
FEISHU_INTERMEDIARY_SUMMARY_APP_TOKEN=your_intermediary_summary_app_token
FEISHU_INTERMEDIARY_SUMMARY_TABLE_ID=your_intermediary_summary_table_id
LEAD_EVENT_LOG_PATH=data/broker_leads.jsonl

