# Safe local test fixture for M0.
# This file intentionally contains no real credentials.
# Tests should copy this file into an isolated temporary directory as `.env`.

APP_ENV=test
PUBLIC_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

WECOM_KF_SECRET=missing-key
WECOM_KF_TOKEN=missing-token
WECOM_KF_AES_KEY=missing-aes-key
WECOM_KF_WELCOME_INTERVAL_SECONDS=600

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-flash
DASHSCOPE_REWRITE_MODEL=qwen-flash
DASHSCOPE_PLANNER_MODEL=qwen-flash
DASHSCOPE_REPLY_MODEL=qwen-plus
DASHSCOPE_SELFCHECK_MODEL=qwen-flash
DASHSCOPE_RETRY_MODEL=qwen-flash

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

LLM_REWRITE_PROVIDER=dashscope
LLM_PLANNER_PROVIDER=dashscope
LLM_REPLY_PROVIDER=dashscope
LLM_SELFCHECK_PROVIDER=dashscope
LLM_RETRY_PROVIDER=dashscope

FEISHU_APP_ID=missing-app-id
FEISHU_APP_SECRET=missing-app-secret
FEISHU_BITABLE_APP_TOKEN=missing-bitable-app-token
FEISHU_BITABLE_TABLE_ID=missing-table-id
FEISHU_BITABLE_VIEW_ID=missing-view-id
FEISHU_DRIVE_ROOT_FOLDER_TOKEN=missing-drive-root
FEISHU_INVENTORY_DRIVE_FOLDER_TOKEN=missing-inventory-folder
FEISHU_REGION_SYNC_SOURCES=[]
FEISHU_REGION_SYNC_TARGET_SPREADSHEET_TOKEN=missing-spreadsheet-token
FEISHU_REGION_SYNC_TARGET_SHEET_ID=missing-sheet-id
FEISHU_REGION_SYNC_TARGET_DRIVE_FOLDER_TOKEN=missing-drive-folder

INVENTORY_SOURCE=local_cache
INVENTORY_CACHE_PATH=data/test_inventory_cache.csv
INVENTORY_CACHE_META_PATH=data/test_inventory_cache_meta.json
REWRITE_INVENTORY_INDEX_PATH=data/test_rewrite_inventory_index.json
INVENTORY_SNAPSHOT_MODE=disabled
INVENTORY_SNAPSHOT_SHADOW_ROOT=data/test_inventory_snapshots_shadow
INVENTORY_SNAPSHOT_SHADOW_STALE_SECONDS=86400
INVENTORY_SNAPSHOT_SHADOW_REQUIRED_PASSES=3
INVENTORY_SNAPSHOT_SHADOW_TIMEOUT_SECONDS=10
INVENTORY_SNAPSHOT_SHADOW_REPORT_RETENTION=30
ROOM_DATABASE_PATH=room_database
MEDIA_ROOT=media/rooms

KF_DIALOGUE_EVENT_LOG_PATH=data/test_kf_dialogue_events.jsonl
KF_ISSUE_COLLECTION_ENABLED=false
